{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsOS Agent Manifest",
  "type": "object",
  "required": ["name", "version", "model", "system_prompt", "tools"],
  "properties": {
    "name":         { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,40}$" },
    "version":      { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description":  { "type": "string" },
    "model": {
      "type": "object",
      "required": ["provider", "id"],
      "properties": {
        "provider": { "enum": ["openai", "anthropic", "llama.cpp", "hf"] },
        "id":       { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "max_tokens":  { "type": "integer", "minimum": 1 }
      }
    },
    "system_prompt": { "oneOf": [{ "type": "string" }, { "type": "string", "format": "uri-reference" }] },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policies": {
      "type": "object",
      "properties": {
        "max_steps":    { "type": "integer", "minimum": 1, "default": 25 },
        "max_cost_usd": { "type": "number",  "minimum": 0, "default": 1.00 },
        "timeout_s":    { "type": "integer", "minimum": 1, "default": 600 }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "namespaces": { "type": "array", "items": { "type": "string" } },
        "retrieve_k": { "type": "integer", "minimum": 0, "default": 5 }
      }
    }
  }
}